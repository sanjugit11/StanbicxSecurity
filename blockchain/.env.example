# ═══════════════════════════════════════════════════════════════
#  StanbicX Token — Environment Configuration
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# Deployer private key (NEVER commit this to git!)
PRIVATE_KEY=your_private_key_here

# RPC Providers (pick one or both)
INFURA_API_KEY=
ALCHEMY_API_KEY=

# Block explorer verification
ETHERSCAN_API_KEY=

# Gas reporting
REPORT_GAS=false
COINMARKETCAP_KEY=
